generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role{
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  users     User[]
}
model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String   @unique
  password  String
  name      String
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String
  transacoes Transacao[]
}

model TipoTransacao {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  nome       String
  descricao  String
  natureza   String
  numero     String
  transacoes Transacao[]
}


model Loja {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nome      String
  nomeDono  String
  transacoes Transacao[]
}
model Transacao {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  tipo            TipoTransacao @relation(fields: [tipoTransacaoId], references: [id])
  tipoTransacaoId String
  valor           Float
  cpf             String
  cartao          String
  hora            DateTime
  loja            Loja          @relation(fields: [lojaId], references: [id])
  lojaId          String
}
